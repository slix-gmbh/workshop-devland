      "targets": [
        {
          "expr": "sum by (area) (jvm_memory_used_bytes{application=~\"$application\", instance=~\"$instance\", area=~\"heap|nonheap\"})",
          "legendFormat": "{{area}}",
          "refId": "A"
        }
      ],
      "title": "JVM Memory Used (heap / nonheap)",
      "type": "timeseries"
    },
