    {
      "datasource": "Prometheus",
      "description": "Requests/s für die Order-Endpunkte (bike/scooter/car) – aus rideshare.http.order",
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": [] } },
      "targets": [
        {
          "expr": "sum by (vehicle, radius) (rate(rideshare_http_order_seconds_count{application=~\"$application\", instance=~\"$instance\"}[2m]))",
          "legendFormat": "{{vehicle}} r={{radius}}",
          "refId": "A"
        }
      ],
      "title": "Order Throughput (req/s)",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "description": "P50/P95/P99 Latenz (Histogram) für rideshare.http.order",
      "fieldConfig": { "defaults": {}, "overrides": [] },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "options": { "legend": { "displayMode": "table", "placement": "bottom", "calcs": [] } },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(rideshare_http_order_seconds_bucket{application=~\"$application\", instance=~\"$instance\"}[5m])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(rideshare_http_order_seconds_bucket{application=~\"$application\", instance=~\"$instance\"}[5m])))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(rideshare_http_order_seconds_bucket{application=~\"$application\", instance=~\"$instance\"}[5m])))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "title": "Order Latency (p50/p95/p99)",
      "type": "timeseries"
    },
    {
